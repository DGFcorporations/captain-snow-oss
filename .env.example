# ⚓ Captain Snow — environment configuration
# Copy to .env, fill in what you have. Everything is optional except at
# least ONE cloud LLM key. Unset skills simply report "not configured".

# ── LLM cascade (need at least one; all have free tiers) ────────────────────
OPENROUTER_API_KEY=          # https://openrouter.ai/keys        (free tier)
GROQ_API_KEY=                # https://console.groq.com/keys     (free tier)
GEMINI_API_KEY=              # https://aistudio.google.com/apikey (free tier)
QWEN_API_KEY=                # https://modelstudio.console.alibabacloud.com (free quota)
DEEPSEEK_API_KEY=            # https://platform.deepseek.com     (near-free paid)
KIMI_API_KEY=                # https://platform.moonshot.cn      (paid fallback)

# ── Web chat security (strongly recommended) ────────────────────────────────
CAPTAINSNOW_WEB_TOKEN=       # any long random string; gates POST /chat
CAPTAINSNOW_CORS_ORIGINS=    # comma-separated origins allowed to call /chat

# ── Telegram bot (optional) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # from @BotFather
TELEGRAM_OWNER_ID=           # your numeric ID — send /start to @userinfobot
TELEGRAM_CHAT_ID=            # usually same as owner id

# ── Skill integrations (all optional) ────────────────────────────────────────
STRIPE_API_KEY=
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
SUPABASE_URL=
SUPABASE_KEY=
WORDPRESS_URL=
WORDPRESS_USERNAME=
WP_APP_PASSWORD=
GHOST_URL=
GHOST_ADMIN_API_KEY=
GOOGLE_MAPS_API_KEY=
SERPER_API_KEY=              # search upgrade; DuckDuckGo is the free default
ZOHO_SENDER=
ZOHO_APP_PASSWORD=
ZOHO_RECIPIENT=
HUGGINGFACE_API_KEY=
